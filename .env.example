TAVILY_API_KEY=tvly-YOUR_REAL_KEY

# Optional. Defaults to the current OpenClaw workspace's info-alchemist/ directory.
# INFO_ALCHEMIST_DATA_DIR=/absolute/path/to/info-alchemist-data
# INFO_ALCHEMIST_REPORT_DIR=/absolute/path/to/info-alchemist/reports
# INFO_ALCHEMIST_HTML_REPORT_DIR=/absolute/path/to/info-alchemist/reports/html

# Deep research vertical social search via TikHub.
INFO_ALCHEMIST_ENABLE_TIKHUB=1
TIKHUB_API_KEY=YOUR_TIKHUB_BEARER_TOKEN
TIKHUB_API_BASE=https://api.tikhub.io
TIKHUB_PLATFORMS=xhs,x,reddit
TIKHUB_MAX_QUERIES=0
TIKHUB_RESULTS_PER_GROUP=3
